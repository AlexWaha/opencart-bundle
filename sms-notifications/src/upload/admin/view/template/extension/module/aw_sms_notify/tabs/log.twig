<fieldset>
    <div class="form-group">
        <label class="col-sm-2 control-label" for="input-sms-log-file">{{ entry_sms_notify_log_filename }}</label>
        <div class="col-sm-10">
            <input type="text" name="sms_notify_log_filename" value="{{ sms_notify_log_filename }}" placeholder="{{ entry_sms_notify_log_filename }}" id="input-sms-log-file" class="form-control"/>
            {% if error.log_filename %}
                <div class="text-danger">{{ error.log_filename }}</div>
            {% endif %}
        </div>
    </div>
    <div class="form-group">
        <label class="col-sm-2 control-label" for="input-sms-log">{{ entry_sms_log }}</label>
        <div class="col-sm-4">
            <select name="sms_notify_log" id="input-sms-log" class="form-control">
                {% if sms_notify_log %}
                    <option value="1" selected="selected">{{ text_enabled }}</option>
                    <option value="0">{{ text_disabled }}</option>
                {% else %}
                    <option value="1">{{ text_enabled }}</option>
                    <option value="0" selected="selected">{{ text_disabled }}</option>
                {% endif %}
            </select>
        </div>
        <div class="col-sm-4 d-flex align-center">
            <button type="button" id="button-clear-log" data-url="{{ clearLog }}" data-loading-text="{{ text_loading }}" class="btn btn-danger">
                <i class="fa fa-eraser"></i> {{ button_clear }}
            </button>
        </div>
    </div>
    <div class="form-group">
        <div class="col-sm-12">
            <textarea wrap="off" rows="15" readonly id="log-file-content" class="form-control">{{ sms_log }}</textarea>
        </div>
    </div>
</fieldset>
