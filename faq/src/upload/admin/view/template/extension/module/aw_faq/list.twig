{{ header }}{{ column_left }}
<div id="content" class="theme-origin">
    <div class="page-header">
        <div class="container-fluid">
            <div class="pull-right">
                <a href="{{ settings_url }}" class="btn btn-default"><i class="fa fa-cog"></i> {{ text_settings }}</a>
                <a href="{{ add }}" class="btn btn-primary"><i class="fa fa-plus"></i> {{ button_add }}</a>
                <button type="submit" form="form-faq-list" formaction="{{ delete }}"
                        onclick="return confirm('{{ text_confirm }}');"
                        class="btn btn-danger"><i class="fa fa-trash"></i> {{ button_delete }}</button>
            </div>
            <h1>{{ heading_title|raw }}</h1>
            <ul class="breadcrumb">
                {% for breadcrumb in breadcrumbs %}
                    <li><a href="{{ breadcrumb.href }}">{{ breadcrumb.text }}</a></li>
                {% endfor %}
            </ul>
        </div>
    </div>

    <div class="container-fluid">
        {% if error.warning %}
            <div class="alert alert-danger">
                <i class="fa fa-exclamation-circle"></i> {{ error.warning }}
            </div>
        {% endif %}
        {% if success %}
            <div class="alert alert-success">
                <i class="fa fa-check-circle"></i> {{ success }}
            </div>
        {% endif %}

        <div class="panel panel-default">
            <div class="panel-heading">
                <h3 class="panel-title"><i class="fa fa-list"></i> {{ text_list }}</h3>
            </div>
            <div class="panel-body">
                <form action="{{ delete }}" method="post" enctype="multipart/form-data" id="form-faq-list">
                    <div class="table-responsive">
                        <table class="table table-bordered table-hover">
                            <thead>
                            <tr>
                                <th style="width:1px;" class="text-center">
                                    <input type="checkbox" onclick="$('input[name*=\'selected\']').prop('checked', this.checked);" />
                                </th>
                                <th style="width:30px;" class="text-center"><i class="fa fa-arrows" title="Drag to reorder"></i></th>
                                <th>{{ column_question }}</th>
                                <th class="text-center" style="width:100px;">{{ column_status }}</th>
                                <th class="text-center" style="width:100px;">{{ column_sort_order }}</th>
                                <th class="text-center" style="width:100px;">{{ column_date }}</th>
                                <th class="text-right" style="width:80px;">{{ column_action }}</th>
                            </tr>
                            </thead>
                            <tbody id="faq-sortable">
                            {% if faqs %}
                                {% for faq in faqs %}
                                    <tr data-id="{{ faq.faq_id }}">
                                        <td class="text-center">
                                            <input type="checkbox" name="selected[]" value="{{ faq.faq_id }}" />
                                        </td>
                                        <td class="text-center drag-handle" style="cursor:grab;">
                                            <i class="fa fa-bars"></i>
                                        </td>
                                        <td>{{ faq.question }}</td>
                                        <td class="text-center">
                                            {% if faq.status %}
                                                <span class="label label-success">{{ text_enabled }}</span>
                                            {% else %}
                                                <span class="label label-danger">{{ text_disabled }}</span>
                                            {% endif %}
                                        </td>
                                        <td class="text-center">{{ faq.sort_order }}</td>
                                        <td class="text-center">{{ faq.date_added }}</td>
                                        <td class="text-right">
                                            <a href="{{ faq.edit }}" class="btn btn-primary btn-sm">
                                                <i class="fa fa-pencil"></i>
                                            </a>
                                        </td>
                                    </tr>
                                {% endfor %}
                            {% else %}
                                <tr>
                                    <td class="text-center" colspan="7">{{ text_no_results }}</td>
                                </tr>
                            {% endif %}
                            </tbody>
                        </table>
                    </div>
                </form>
                <div class="row">
                    <div class="col-sm-6 text-left">{{ pagination }}</div>
                    <div class="col-sm-6 text-right">{{ results }}</div>
                </div>
            </div>
        </div>
    </div>
</div>
<script src="https://cdn.jsdelivr.net/npm/sortablejs@1.15.0/Sortable.min.js"></script>
<script>
(function() {
    'use strict';

    var el = document.getElementById('faq-sortable');
    if (!el) return;

    Sortable.create(el, {
        handle: '.drag-handle',
        animation: 150,
        onEnd: function() {
            var order = [];
            var rows = el.querySelectorAll('tr[data-id]');
            for (var i = 0; i < rows.length; i++) {
                order.push(rows[i].getAttribute('data-id'));
            }

            $.ajax({
                url: '{{ sort_url }}',
                type: 'POST',
                dataType: 'json',
                data: { order: order },
                success: function(json) {
                    if (json.success) {
                        // Update sort order numbers in the table
                        rows = el.querySelectorAll('tr[data-id]');
                        for (var i = 0; i < rows.length; i++) {
                            rows[i].querySelectorAll('td')[4].textContent = i;
                        }
                    }
                }
            });
        }
    });
})();
</script>
{{ footer }}
