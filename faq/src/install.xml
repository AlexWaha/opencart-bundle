<?xml version="1.0" encoding="utf-8"?>
<modification>
	<name>alexwaha.com - FAQ</name>
	<version>1.0.1</version>
	<author>AlexWaha</author>
	<code>aw_faq_menu</code>
	<description>Adds FAQ link to Catalog menu in admin panel</description>

	<file path="admin/controller/common/column_left.php">
		<operation>
			<search><![CDATA[if ($catalog) {]]></search>
			<add position="before"><![CDATA[
			if ($this->user->hasPermission('access', 'extension/module/aw_faq')) {
				$catalog[] = array(
					'name'	   => 'FAQ',
					'href'     => $this->url->link('extension/module/aw_faq', 'user_token=' . $this->session->data['user_token'], true),
					'children' => array()
				);
			}
]]></add>
		</operation>
	</file>
</modification>
