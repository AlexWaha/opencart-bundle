<div class="form-group">
    <label class="col-sm-3 control-label">{{ entry_status }}</label>
    <div class="col-sm-9">
        <label class="checkbox-switch">
            <input type="hidden" name="status" value="0">
            <input type="checkbox" name="status" value="1" {% if status %}checked{% endif %}>
            <span class="checkbox-switch-slider"></span>
        </label>
    </div>
</div>
<div class="form-group">
    <label class="col-sm-3 control-label">{{ entry_per_page }}</label>
    <div class="col-sm-9">
        <input type="number" name="per_page" value="{{ per_page }}" class="form-control" min="1" max="100" style="width:120px;">
    </div>
</div>

<hr>
<h4>SEO</h4>
<div class="form-group">
    <label class="col-sm-3 control-label">SEO URL</label>
    <div class="col-sm-9">
        <table class="table table-bordered">
            <thead><tr><th>{{ entry_store }}</th><th>SEO URL</th></tr></thead>
            <tbody>
            {% for store in stores %}
            <tr>
                <td>{{ store.name }}</td>
                <td>
                    {% for language in languages %}
                    <div class="input-group" style="margin-bottom:3px;">
                        <span class="input-group-addon" style="padding:3px 6px;">
                            <img src="language/{{ language.code }}/{{ language.code }}.png" title="{{ language.name }}">
                        </span>
                        <input type="text" name="seo_url[{{ store.store_id }}][{{ language.language_id }}]"
                               value="{{ seo_url[store.store_id][language.language_id] ?? '' }}"
                               class="form-control" placeholder="testimonial">
                        {% if error.seo_url[store.store_id][language.language_id] is defined %}
                        <div class="text-danger">{{ error.seo_url[store.store_id][language.language_id] }}</div>
                        {% endif %}
                    </div>
                    {% endfor %}
                </td>
            </tr>
            {% endfor %}
            </tbody>
        </table>
    </div>
</div>
<ul class="nav nav-tabs" style="margin-bottom:15px;">
    {% for language in languages %}
    <li{% if loop.first %} class="active"{% endif %}>
        <a href="#seo-lang-{{ language.language_id }}" data-toggle="tab">
            <img src="language/{{ language.code }}/{{ language.code }}.png" title="{{ language.name }}"> {{ language.name }}
        </a>
    </li>
    {% endfor %}
</ul>
<div class="tab-content">
    {% for language in languages %}
    <div class="tab-pane{% if loop.first %} active{% endif %}" id="seo-lang-{{ language.language_id }}">
        <div class="form-group">
            <label class="col-sm-3 control-label">{{ entry_meta_title }}</label>
            <div class="col-sm-9">
                <input type="text" name="seo[meta_title][{{ language.language_id }}]"
                       value="{{ seo.meta_title[language.language_id] ?? '' }}"
                       class="form-control">
            </div>
        </div>
        <div class="form-group">
            <label class="col-sm-3 control-label">{{ entry_meta_description }}</label>
            <div class="col-sm-9">
                <textarea name="seo[meta_description][{{ language.language_id }}]"
                          rows="3" class="form-control">{{ seo.meta_description[language.language_id] ?? '' }}</textarea>
            </div>
        </div>
        <div class="form-group">
            <label class="col-sm-3 control-label">{{ entry_meta_h1 }}</label>
            <div class="col-sm-9">
                <input type="text" name="seo[meta_h1][{{ language.language_id }}]"
                       value="{{ seo.meta_h1[language.language_id] ?? '' }}"
                       class="form-control">
            </div>
        </div>
    </div>
    {% endfor %}
</div>
