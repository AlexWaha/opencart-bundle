{{ header }}{{ column_left }}
<div id="content" class="theme-origin">
    <div class="page-header">
        <div class="container-fluid">
            <div class="pull-right">
                <a href="{{ settings_url }}" data-toggle="tooltip" title="{{ text_settings }}" class="btn btn-default"><i class="fa fa-cog"></i></a>
                <a href="{{ add }}" class="btn btn-primary"><i class="fa fa-plus"></i> {{ button_add }}</a>
                <button type="submit" form="form-review-list" formaction="{{ delete }}"
                        onclick="return confirm('{{ text_confirm }}');"
                        class="btn btn-danger"><i class="fa fa-trash"></i> {{ button_delete }}</button>
            </div>
            <h1>{{ heading_title|raw }}</h1>
            <ul class="breadcrumb">
                {% for breadcrumb in breadcrumbs %}
                    <li><a href="{{ breadcrumb.href }}">{{ breadcrumb.text }}</a></li>
                {% endfor %}
            </ul>
        </div>
    </div>

    <div class="container-fluid">
        {% if error.warning %}
            <div class="alert alert-danger">
                <i class="fa fa-exclamation-circle"></i> {{ error.warning }}
            </div>
        {% endif %}
        {% if success %}
            <div class="alert alert-success">
                <i class="fa fa-check-circle"></i> {{ success }}
            </div>
        {% endif %}

        <div class="panel panel-default">
            <div class="panel-heading">
                <h3 class="panel-title"><i class="fa fa-list"></i> {{ text_list }}</h3>
            </div>
            <div class="panel-body">
                <div class="well">
                    <div class="row">
                        <div class="col-sm-4">
                            <div class="form-group">
                                <label>{{ entry_status }}</label>
                                <select name="filter_status" id="input-filter-status" class="form-control">
                                    <option value="">{{ text_all_statuses }}</option>
                                    <option value="1" {% if filter_status == '1' %}selected{% endif %}>{{ text_enabled }}</option>
                                    <option value="0" {% if filter_status == '0' %}selected{% endif %}>{{ text_disabled }}</option>
                                </select>
                            </div>
                        </div>
                        <div class="col-sm-2">
                            <div class="form-group">
                                <label>&nbsp;</label>
                                <button type="button" id="btn-filter" class="btn btn-primary btn-block">
                                    <i class="fa fa-filter"></i> {{ button_filter }}
                                </button>
                            </div>
                        </div>
                    </div>
                </div>

                <form action="{{ delete }}" method="post" enctype="multipart/form-data" id="form-review-list">
                    <div class="table-responsive">
                        <table class="table table-bordered table-hover">
                            <thead>
                            <tr>
                                <th style="width:1px;" class="text-center">
                                    <input type="checkbox" onclick="$('input[name*=\'selected\']').prop('checked', this.checked);" />
                                </th>
                                <th>{{ column_author }}</th>
                                <th>{{ column_city }}</th>
                                <th class="text-center">{{ column_rating }}</th>
                                <th>{{ column_text }}</th>
                                <th class="text-center">{{ column_status }}</th>
                                <th class="text-center">{{ column_date }}</th>
                                <th class="text-right">{{ column_action }}</th>
                            </tr>
                            </thead>
                            <tbody>
                            {% if reviews %}
                                {% for review in reviews %}
                                    <tr>
                                        <td class="text-center">
                                            <input type="checkbox" name="selected[]" value="{{ review.review_id }}" />
                                        </td>
                                        <td>{{ review.author }}</td>
                                        <td>{{ review.city }}</td>
                                        <td class="text-center" style="color:#f90;">
                                            {% for i in 1..5 %}
                                                {% if i <= review.rating %}
                                                    <i class="fa fa-star"></i>
                                                {% else %}
                                                    <i class="fa fa-star-o"></i>
                                                {% endif %}
                                            {% endfor %}
                                        </td>
                                        <td>{{ review.text }}</td>
                                        <td class="text-center">
                                            {% if review.status %}
                                                <span class="label label-success">{{ text_enabled }}</span>
                                            {% else %}
                                                <span class="label label-danger">{{ text_disabled }}</span>
                                            {% endif %}
                                        </td>
                                        <td class="text-center">{{ review.date_added }}</td>
                                        <td class="text-right">
                                            <a href="{{ review.edit }}" class="btn btn-primary btn-sm">
                                                <i class="fa fa-pencil"></i>
                                            </a>
                                        </td>
                                    </tr>
                                {% endfor %}
                            {% else %}
                                <tr>
                                    <td class="text-center" colspan="8">{{ text_no_results }}</td>
                                </tr>
                            {% endif %}
                            </tbody>
                        </table>
                    </div>
                </form>
                <div class="row">
                    <div class="col-sm-6 text-left">{{ pagination }}</div>
                    <div class="col-sm-6 text-right">{{ results }}</div>
                </div>
            </div>
        </div>
    </div>
</div>
<script>
$('#btn-filter').on('click', function() {
    var status = $('#input-filter-status').val();

    var base = window.location.href.split('?')[0];
    var params = new URLSearchParams(window.location.search);

    if (status !== '') {
        params.set('filter_status', status);
    } else {
        params.delete('filter_status');
    }

    params.delete('page');

    window.location.href = base + '?' + params.toString();
});
</script>
{{ footer }}
