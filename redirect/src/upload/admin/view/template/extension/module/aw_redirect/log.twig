{{ header }}{{ column_left }}
<div id="content" class="theme-origin">
    <div class="page-header">
        <div class="container-fluid">
            <div class="pull-right">
                <a href="{{ back }}" class="btn btn-default"><i class="fa fa-reply"></i> {{ text_back }}</a>
                <a href="{{ clear_log }}" onclick="return confirm('{{ text_confirm_clear }}');" class="btn btn-danger"><i class="fa fa-eraser"></i> {{ button_clear }}</a>
            </div>
            <h1>{{ heading_title|raw }}</h1>
            <ul class="breadcrumb">
                {% for breadcrumb in breadcrumbs %}
                    <li><a href="{{ breadcrumb.href }}">{{ breadcrumb.text }}</a></li>
                {% endfor %}
            </ul>
        </div>
    </div>

    <div class="container-fluid">
        {% if success %}
            <div class="alert alert-success"><i class="fa fa-check-circle"></i> {{ success }}</div>
        {% endif %}

        <div class="panel panel-default">
            <div class="panel-heading">
                <h3 class="panel-title"><i class="fa fa-bug"></i> {{ text_log }}</h3>
            </div>
            <div class="panel-body">
                <div class="alert alert-info"><i class="fa fa-info-circle"></i> {{ text_log_info }}</div>

                <div class="well">
                    <div class="row">
                        <div class="col-sm-6">
                            <div class="form-group">
                                <label>{{ column_url }}</label>
                                <input type="text" id="filter-url" value="{{ filter_url }}" class="form-control"/>
                            </div>
                        </div>
                        <div class="col-sm-2">
                            <div class="form-group">
                                <label>&nbsp;</label>
                                <button type="button" id="btn-filter" class="btn btn-primary btn-block"><i class="fa fa-filter"></i> {{ button_filter }}</button>
                            </div>
                        </div>
                    </div>
                </div>

                <form method="post" enctype="multipart/form-data" id="form-log">
                    <div class="table-responsive">
                        <table class="table table-bordered table-hover">
                            <thead>
                            <tr>
                                <th style="width:1px;" class="text-center">
                                    <input type="checkbox" onclick="$('input[name*=\'selected\']').prop('checked', this.checked);" />
                                </th>
                                <th>{{ column_url }}</th>
                                <th class="text-center" style="width:70px;">{{ column_hits }}</th>
                                <th class="text-center" style="width:140px;">{{ column_last_seen }}</th>
                                <th class="text-right" style="width:150px;">{{ column_action }}</th>
                            </tr>
                            </thead>
                            <tbody>
                            {% if logs %}
                                {% for log in logs %}
                                    <tr>
                                        <td class="text-center"><input type="checkbox" name="selected[]" value="{{ log.log_id }}"/></td>
                                        <td><span class="badge-code">{{ log.url }}</span></td>
                                        <td class="text-center">{{ log.hits }}</td>
                                        <td class="text-center">{{ log.date_modified }}</td>
                                        <td class="text-right">
                                            <a href="{{ log.create }}" class="btn btn-success btn-sm"><i class="fa fa-plus"></i> {{ button_create }}</a>
                                        </td>
                                    </tr>
                                {% endfor %}
                            {% else %}
                                <tr><td class="text-center" colspan="5">{{ text_no_results }}</td></tr>
                            {% endif %}
                            </tbody>
                        </table>
                    </div>
                    <div class="d-flex gap-10">
                        <button type="submit" formaction="{{ redirect_home }}" onclick="return confirm('{{ text_confirm_home }}');" class="btn btn-primary"><i class="fa fa-home"></i> {{ button_redirect_home }}</button>
                        <button type="submit" formaction="{{ delete_log }}" onclick="return confirm('{{ text_confirm }}');" class="btn btn-danger"><i class="fa fa-trash"></i> {{ button_delete }}</button>
                    </div>
                </form>
                <div class="row" style="margin-top:15px;">
                    <div class="col-sm-6 text-left">{{ pagination }}</div>
                    <div class="col-sm-6 text-right">{{ results }}</div>
                </div>
            </div>
        </div>
    </div>
</div>
<script>
(function () {
    'use strict';
    document.getElementById('btn-filter').addEventListener('click', function () {
        var params = new URLSearchParams(window.location.search);
        var val = document.getElementById('filter-url').value;
        if (val !== '') { params.set('filter_url', val); } else { params.delete('filter_url'); }
        params.delete('page');
        window.location.search = params.toString();
    });
})();
</script>
{{ footer }}
