{{ header }}{{ column_left }}
<div id="content" class="theme-origin">
    <div class="page-header">
        <div class="container-fluid">
            <div class="pull-right">
                <button type="submit" form="form-redirect" data-toggle="tooltip" title="{{ button_save }}" class="btn btn-primary"><i class="fa fa-save"></i></button>
                <a href="{{ cancel }}" data-toggle="tooltip" title="{{ button_cancel }}" class="btn btn-default"><i class="fa fa-reply"></i></a>
            </div>
            <h1>{{ heading_title|raw }}</h1>
            <ul class="breadcrumb">
                {% for breadcrumb in breadcrumbs %}
                    <li><a href="{{ breadcrumb.href }}">{{ breadcrumb.text }}</a></li>
                {% endfor %}
            </ul>
        </div>
    </div>

    <div class="container-fluid">
        {% if error.warning %}
            <div class="alert alert-danger"><i class="fa fa-exclamation-circle"></i> {{ error.warning }}</div>
        {% endif %}

        <div class="panel panel-default">
            <div class="panel-heading">
                <h3 class="panel-title"><i class="fa fa-pencil"></i> {{ redirect_id ? text_edit : text_add }}</h3>
            </div>
            <div class="panel-body">
                <form action="{{ action }}" method="post" enctype="multipart/form-data" id="form-redirect" class="form-horizontal">
                    <div class="form-group required">
                        <label class="col-sm-3 control-label" for="input-source">{{ entry_source }}</label>
                        <div class="col-xs-9 col-sm-6">
                            <input type="text" name="source" value="{{ source }}" placeholder="/old-page or /blog/*" id="input-source" class="form-control"/>
                            {% if error.source %}<div class="text-danger">{{ error.source }}</div>{% endif %}
                            <p class="help-block">{{ help_source }}</p>
                        </div>
                    </div>

                    <div class="form-group">
                        <div class="col-sm-3 control-label">{{ entry_match_query }}</div>
                        <label class="col-xs-9 col-sm-6 checkbox-switch" for="match_query">
                            <input type="hidden" name="match_query" value="0" id="match_query-off" {% if not match_query %}checked="checked"{% endif %}/>
                            <input type="checkbox" name="match_query" value="1" id="match_query" {% if match_query %}checked="checked"{% endif %}/>
                        </label>
                        <div class="col-xs-12 col-sm-offset-3 col-sm-9"><p class="help-block">{{ help_match_query }}</p></div>
                    </div>

                    <div class="form-group required">
                        <label class="col-sm-3 control-label" for="input-target">{{ entry_target }}</label>
                        <div class="col-xs-9 col-sm-6">
                            <input type="text" name="target" value="{{ target }}" placeholder="/new-page or https://..." id="input-target" class="form-control"/>
                            {% if error.target %}<div class="text-danger">{{ error.target }}</div>{% endif %}
                            <p class="help-block">{{ help_target }}</p>
                        </div>
                    </div>

                    <div class="form-group">
                        <label class="col-sm-3 control-label" for="input-code">{{ entry_code }}</label>
                        <div class="col-xs-9 col-sm-6">
                            <select name="status_code" id="input-code" class="form-control">
                                {% for code in status_codes %}
                                    <option value="{{ code }}" {{ status_code == code ? 'selected' }}>{{ code }}</option>
                                {% endfor %}
                            </select>
                            <p class="help-block">{{ help_code }}</p>
                        </div>
                    </div>

                    <div class="form-group">
                        <label class="col-sm-3 control-label" for="input-store">{{ entry_store }}</label>
                        <div class="col-xs-9 col-sm-6">
                            <select name="store_id" id="input-store" class="form-control">
                                {% for store in stores %}
                                    <option value="{{ store.store_id }}" {{ store_id == store.store_id ? 'selected' }}>{{ store.name }}</option>
                                {% endfor %}
                            </select>
                        </div>
                    </div>

                    <div class="form-group">
                        <div class="col-sm-3 control-label">{{ entry_status }}</div>
                        <label class="col-xs-9 col-sm-6 checkbox-switch" for="status">
                            <input type="hidden" name="status" value="0" id="status-off" {% if not status %}checked="checked"{% endif %}/>
                            <input type="checkbox" name="status" value="1" id="status" {% if status %}checked="checked"{% endif %}/>
                        </label>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>
{{ footer }}
