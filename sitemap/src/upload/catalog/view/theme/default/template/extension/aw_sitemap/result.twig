<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="robots" content="noindex,nofollow">
    <title>{{ text_result_title }}</title>
    <style>
        body { font-family: Arial, sans-serif; margin: 40px; color: #333; }
        .box { max-width: 640px; padding: 24px; border: 1px solid #d6e9c6; background: #dff0d8; border-radius: 4px; }
        a { color: #0937cc; }
        .meta { margin-top: 12px; color: #555; }
    </style>
</head>
<body>
    <div class="box">
        <h2>{{ text_result_done }}</h2>
        <p><a href="{{ index_url }}" target="_blank">{{ index_url }}</a></p>
        <p class="meta">{{ text_result_shards }}: {{ shard_count }}</p>
    </div>
</body>
</html>
