{{ header }}{{ column_left }}
<div id="content" class="theme-origin">
    <div class="page-header">
        <div class="container-fluid">
            <div class="pull-right">
                <button type="submit" form="form-microdata" data-toggle="tooltip" title="{{ button_save }}" class="btn btn-primary"><i class="fa fa-save"></i></button>
                <a href="{{ cancel }}" data-toggle="tooltip" title="{{ button_cancel }}" class="btn btn-default"><i class="fa fa-reply"></i></a>
            </div>
            <h1>{{ heading_title|raw }}</h1>
            <ul class="breadcrumb">
                {% for breadcrumb in breadcrumbs %}
                <li><a href="{{ breadcrumb.href }}">{{ breadcrumb.text }}</a></li>
                {% endfor %}
            </ul>
        </div>
    </div>
    <div class="container-fluid">
        {% if error.warning %}
        <div class="alert alert-danger"><i class="fa fa-exclamation-circle"></i> {{ error.warning }}<button type="button" class="close" data-dismiss="alert">&times;</button></div>
        {% endif %}
        {% if success %}
        <div class="alert alert-success"><i class="fa fa-check-circle"></i> {{ success }}</div>
        {% endif %}

        <div class="panel panel-default">
            <div class="panel-heading"><h3 class="panel-title"><i class="fa fa-pencil"></i> {{ text_edit }}</h3></div>
            <div class="panel-body">
                <form action="{{ action }}" method="post" enctype="multipart/form-data" id="form-microdata" class="form-horizontal">
                    <div class="row">
                        <div class="col-sm-3">
                            {% set tabs = [
                                { id: 'diagnostics', label: tab_diagnostics, icon: 'fa-stethoscope' },
                                { id: 'general', label: tab_general, icon: '' },
                                { id: 'organization', label: tab_organization, icon: '' },
                                { id: 'products', label: tab_products, icon: '' },
                                { id: 'categories', label: tab_categories, icon: '' },
                                { id: 'content', label: tab_content, icon: '' },
                                { id: 'og', label: tab_og, icon: '' },
                                { id: 'advanced', label: tab_advanced, icon: '' },
                                { id: 'import_export', label: tab_import_export, icon: '' },
                                { id: 'support', label: tab_support, icon: '' }
                            ] %}
                            {% set active_tab = 'diagnostics' %}

                            {% include 'extension/module/aw_microdata/v-tabs-nav.twig' with {
                                tabs: tabs,
                                active_tab: active_tab
                            } %}
                        </div>
                        <div class="col-sm-9">
                            <div class="tab-content">
                                {% for t in tabs %}
                                    {% set is_active = (active_tab == t.id) or (active_tab is not defined and loop.first) %}
                                    <div id="v-tab_{{ t.id }}" class="tab-pane {{ is_active ? 'active' }}">
                                        {% include 'extension/module/aw_microdata/tabs/' ~ t.id ~ '.twig' ignore missing %}
                                    </div>
                                {% endfor %}
                            </div>
                        </div>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

<script>
(function() {
    'use strict';

    var phoneIndex = {{ phones|length }};
    var socialIndex = {{ social|length }};
    var sameasIndex = {{ competitor_sameas|length }};
    var contactPointIndex = {{ contact_points|length }};
    var speakableIndex = {{ speakable_selectors|length }};

    // Phone repeater
    document.addEventListener('click', function(e) {
        if (e.target.closest('#btn-add-phone')) {
            e.preventDefault();
            var row = document.createElement('div');
            row.className = 'input-group input-group-sm phone-row';
            row.style.marginBottom = '3px';
            row.innerHTML = '<input type="text" name="phones[' + phoneIndex + '][number]" value="" class="form-control" placeholder="+380971064609">' +
                '<span class="input-group-btn"><button type="button" class="btn btn-danger btn-sm btn-remove-phone"><i class="fa fa-trash"></i></button></span>';
            document.getElementById('phone-repeater').appendChild(row);
            phoneIndex++;
        }

        if (e.target.closest('.btn-remove-phone')) {
            e.preventDefault();
            e.target.closest('.phone-row').remove();
        }
    });

    // Social repeater
    document.addEventListener('click', function(e) {
        if (e.target.closest('#btn-add-social')) {
            e.preventDefault();
            var row = document.createElement('div');
            row.className = 'input-group input-group-sm social-row';
            row.style.marginBottom = '3px';
            row.innerHTML = '<input type="url" name="social[' + socialIndex + ']" value="" class="form-control" placeholder="https://...">' +
                '<span class="input-group-btn"><button type="button" class="btn btn-danger btn-sm btn-remove-social"><i class="fa fa-trash"></i></button></span>';
            document.getElementById('social-repeater').appendChild(row);
            socialIndex++;
        }

        if (e.target.closest('.btn-remove-social')) {
            e.preventDefault();
            e.target.closest('.social-row').remove();
        }
    });

    // SameAs repeater
    document.addEventListener('click', function(e) {
        if (e.target.closest('#btn-add-sameas')) {
            e.preventDefault();
            var row = document.createElement('div');
            row.className = 'input-group input-group-sm sameas-row';
            row.style.marginBottom = '3px';
            row.innerHTML = '<input type="url" name="competitor_sameas[' + sameasIndex + ']" value="" class="form-control" placeholder="https://competitor.com">' +
                '<span class="input-group-btn"><button type="button" class="btn btn-danger btn-sm btn-remove-sameas"><i class="fa fa-trash"></i></button></span>';
            document.getElementById('sameas-repeater').appendChild(row);
            sameasIndex++;
        }

        if (e.target.closest('.btn-remove-sameas')) {
            e.preventDefault();
            e.target.closest('.sameas-row').remove();
        }
    });

    // ContactPoint repeater (item 14)
    document.addEventListener('click', function(e) {
        if (e.target.closest('#btn-add-contactpoint')) {
            e.preventDefault();
            var i = contactPointIndex;
            var row = document.createElement('div');
            row.className = 'contactpoint-row';
            row.style.cssText = 'border:1px solid #e0e0e0;padding:10px;margin-bottom:6px;border-radius:3px;background:#fafafa;';
            row.innerHTML = '<div class="d-flex gap-10" style="margin-bottom:6px;">' +
                '<input type="text" name="contact_points[' + i + '][telephone]" value="" class="form-control input-sm" placeholder="+380...">' +
                '<input type="text" name="contact_points[' + i + '][contact_type]" value="customer service" class="form-control input-sm">' +
                '<button type="button" class="btn btn-danger btn-sm btn-remove-contactpoint"><i class="fa fa-trash"></i></button>' +
                '</div>' +
                '<input type="text" name="contact_points[' + i + '][area_served][]" value="" class="form-control input-sm" placeholder="Area (one per row)" style="margin-bottom:3px;">' +
                '<input type="text" name="contact_points[' + i + '][available_language][]" value="" class="form-control input-sm" placeholder="Language (one per row)">';
            document.getElementById('contactpoint-repeater').appendChild(row);
            contactPointIndex++;
        }

        if (e.target.closest('.btn-remove-contactpoint')) {
            e.preventDefault();
            e.target.closest('.contactpoint-row').remove();
        }
    });

    // Speakable selectors repeater (item 30)
    document.addEventListener('click', function(e) {
        if (e.target.closest('#btn-add-speakable')) {
            e.preventDefault();
            var row = document.createElement('div');
            row.className = 'input-group input-group-sm speakable-row';
            row.style.marginBottom = '3px';
            row.innerHTML = '<input type="text" name="speakable_selectors[' + speakableIndex + ']" value="" class="form-control" placeholder=".product-name, h1">' +
                '<span class="input-group-btn"><button type="button" class="btn btn-danger btn-sm btn-remove-speakable"><i class="fa fa-trash"></i></button></span>';
            document.getElementById('speakable-repeater').appendChild(row);
            speakableIndex++;
        }

        if (e.target.closest('.btn-remove-speakable')) {
            e.preventDefault();
            e.target.closest('.speakable-row').remove();
        }
    });

    // Diagnostics
    (function() {
        var diagLang = {
            eventsOk: '{{ text_events_ok }}',
            eventsMissing: '{{ text_events_missing }}',
            eventsCount: '{{ text_events_count }}',
            noDuplicates: '{{ text_no_duplicates }}',
            duplicatesFound: '{{ text_duplicates_found }}',
            configOk: '{{ text_config_ok }}',
            configMissing: '{{ text_config_missing }}',
            missingFields: '{{ text_missing_fields }}',
            validateGoogle: '{{ text_validate_google }}',
            diagFailed: '{{ text_diag_failed }}',
            eventOk: '{{ text_event_ok }}',
            eventMissing: '{{ text_event_missing }}',
            goToTab: '{{ text_go_to_tab }}'
        };

        $.getJSON('index.php?route=extension/module/aw_microdata/diagnostics&{{ token_param }}', function(data) {
            var html = '';
            var issues = 0;

            // Events check
            var evtOk = data.events.status === 'ok';
            var evtBoxClass = evtOk ? 'alert-box alert-box-success' : 'alert-box alert-box-danger';
            var evtIcon = evtOk ? 'check-circle' : 'times-circle';
            var evtTitle = evtOk ? diagLang.eventsOk : diagLang.eventsMissing;
            var evtCount = diagLang.eventsCount.replace('%s', data.events.registered).replace('%s', data.events.total);
            if (!evtOk) issues++;

            html += '<div class="' + evtBoxClass + '">';
            html += '<div style="margin-bottom:8px;"><i class="fa fa-' + evtIcon + '"></i> <strong>' + evtTitle + '</strong> <span style="opacity:0.7;">(' + evtCount + ')</span></div>';
            if (data.events.details && data.events.details.length) {
                data.events.details.forEach(function(d) {
                    var ok = d.exists && d.enabled;
                    html += '<div class="list-item" style="margin-bottom:4px;">';
                    html += '<span class="badge-code" style="margin-right:8px;">' + d.trigger + '</span>';
                    html += ok ? '<span class="badge-success" style="color:#fff;">' + diagLang.eventOk + '</span>' : '<span class="badge-danger" style="color:#fff;">' + diagLang.eventMissing + '</span>';
                    html += '</div>';
                });
            }
            html += '</div>';

            // Duplicates check
            if (data.duplicates.files && data.duplicates.files.length) {
                issues++;
                html += '<div class="alert-box alert-box-warning">';
                html += '<div style="margin-bottom:8px;"><i class="fa fa-exclamation-triangle"></i> <strong>' + diagLang.duplicatesFound + '</strong></div>';
                data.duplicates.files.forEach(function(f) {
                    html += '<div class="list-item" style="margin-bottom:4px;"><span class="badge-code">' + f + '</span></div>';
                });
                html += '</div>';
            } else {
                html += '<div class="alert-box alert-box-success"><i class="fa fa-check-circle"></i> <strong>' + diagLang.noDuplicates + '</strong></div>';
            }

            // Config check
            if (data.config.missing && data.config.missing.length) {
                issues++;
                html += '<div class="alert-box alert-box-warning">';
                html += '<div style="margin-bottom:8px;"><i class="fa fa-exclamation-triangle"></i> <strong>' + diagLang.missingFields + '</strong></div>';
                data.config.missing.forEach(function(f) {
                    var field = typeof f === 'object' ? f.field : f;
                    var tab = typeof f === 'object' ? f.tab : '';
                    var tabLink = '';
                    if (tab) {
                        tabLink = ' — <a href="#" onclick="$(\'a[href=#v-tab_' + tab + ']\').click(); return false;">' + diagLang.goToTab + '</a>';
                    }
                    html += '<div class="list-item" style="margin-bottom:4px;"><span class="badge-code">' + field + '</span>' + tabLink + '</div>';
                });
                html += '</div>';
            } else {
                html += '<div class="alert-box alert-box-success"><i class="fa fa-check-circle"></i> <strong>' + diagLang.configOk + '</strong></div>';
            }

            // Validation URLs
            if (data.validation_urls && data.validation_urls.length) {
                html += '<div class="alert-box alert-box-info">';
                html += '<div style="margin-bottom:10px;"><i class="fa fa-external-link"></i> <strong>' + diagLang.validateGoogle + '</strong></div>';
                data.validation_urls.forEach(function(v) {
                    html += '<div class="list-item" style="margin-bottom:4px;">';
                    html += '<a href="' + v.google_url + '" target="_blank" style="text-decoration:none;">';
                    html += '<i class="fa fa-google" style="margin-right:6px;"></i> ' + v.name + ' <small style="opacity:0.6;">(' + v.url + ')</small>';
                    html += '</a>';
                    html += '</div>';
                });
                html += '</div>';
            }

            $('#diagnostics-container').html(html);

            // Update badge
            if (issues > 0) {
                $('#diag-badge').text(issues).css({'background-color': '#d9534f', 'color': '#fff'}).show();
            } else {
                $('#diag-badge').text('OK').css({'background-color': '#5cb85c', 'color': '#fff'}).show();
            }
        }).fail(function() {
            $('#diagnostics-container').html('<div class="alert-box alert-box-danger"><i class="fa fa-times-circle"></i> <strong>' + diagLang.diagFailed + '</strong></div>');
        });
    })();

    // Export
    $('#btn-export-config').on('click', function() {
        var btn = $(this);
        btn.button('loading');
        window.location.href = 'index.php?route=extension/module/{{ module_name }}/exportConfig&{{ token_param }}';
        setTimeout(function() { btn.button('reset'); }, 2000);
    });

    // Import
    $('#btn-import-config').on('click', function() {
        $('#import-file').trigger('click');
    });

    $('#import-file').on('change', function() {
        var fileInput = $(this);
        var importBtn = $('#btn-import-config');

        if (!fileInput.val()) return;

        if (confirm('{{ text_import_warning|replace({"<strong>": "", "</strong>": ""})|striptags }}')) {
            var formData = new FormData();
            formData.append('import_file', fileInput[0].files[0]);
            var $vTab = $('#v-tab_import_export');
            importBtn.button('loading');

            $.ajax({
                url: 'index.php?route=extension/module/{{ module_name }}/importConfig&{{ token_param }}',
                type: 'POST',
                data: formData,
                dataType: 'json',
                cache: false,
                contentType: false,
                processData: false,
                beforeSend: function() { importBtn.prop('disabled', true); },
                complete: function() { importBtn.prop('disabled', false); },
                success: function(json) {
                    $vTab.find('.alert-dismissable').remove();
                    importBtn.button('reset');

                    if (json.error) {
                        $vTab.prepend('<div class="alert alert-danger alert-dismissable"><i class="fa fa-exclamation-circle"></i> ' + json.error + '<button type="button" class="close" data-dismiss="alert">&times;</button></div>');
                    }

                    if (json.success) {
                        $vTab.prepend('<div class="alert alert-success"><i class="fa fa-check-circle"></i> {{ text_import_success }}<button type="button" class="close" data-dismiss="alert">&times;</button></div>');
                        setTimeout(function() { location.reload(); }, 1500);
                    }
                },
                error: function(xhr, ajaxOptions, thrownError) {
                    importBtn.button('reset');
                    $vTab.find('.alert-dismissable').remove();
                    $vTab.prepend('<div class="alert alert-danger"><i class="fa fa-exclamation-circle"></i> ' + thrownError + '<button type="button" class="close" data-dismiss="alert">&times;</button></div>');
                }
            });
        } else {
            fileInput.val('');
        }
    });
})();

// Time picker (bootstrap-datetimepicker)
$('.time-picker').datetimepicker({
    format: 'HH:mm',
    stepping: 15,
    icons: {
        up: 'fa fa-chevron-up',
        down: 'fa fa-chevron-down'
    }
});

// Filemanager for image fields
var imageBaseUrl = '{{ image_url }}';

function openFileManager(inputId) {
    $('#modal-image').remove();
    $.ajax({
        url: 'index.php?route=common/filemanager&user_token=' + getURLVar('user_token'),
        dataType: 'html',
        success: function(html) {
            $('body').append('<div id="modal-image" class="modal">' + html + '</div>');
            $('#modal-image').modal('show');
            $('#modal-image').delegate('a.thumbnail', 'click', function(e) {
                e.preventDefault();
                var path = $(this).attr('href');
                $('#' + inputId).val(path);
                $('#preview-' + inputId.replace('input-', '')).html('<img src="' + imageBaseUrl + path + '" class="img-thumbnail" style="max-height:80px;">');
                $('#modal-image').modal('hide');
            });
        }
    });
}

$('#button-default-image').on('click', function() { openFileManager('input-default-image'); });
$('#button-logo').on('click', function() { openFileManager('input-logo'); });
$('#button-og-image').on('click', function() { openFileManager('input-og-image'); });
</script>
{{ footer }}
