<div class="form-group">
    <label class="col-sm-3 control-label">{{ entry_info_schema }}</label>
    <div class="col-sm-9">
        <label class="checkbox-switch">
            <input type="hidden" name="info_schema" value="0">
            <input type="checkbox" name="info_schema" value="1" {% if info_schema %}checked{% endif %}>
            <span class="checkbox-switch-slider"></span>
        </label>
    </div>
</div>

<div class="form-group">
    <label class="col-sm-3 control-label">{{ entry_info_type }}</label>
    <div class="col-sm-9">
        <select name="info_type" class="form-control">
            <option value="Article" {% if info_type == 'Article' %}selected{% endif %}>Article</option>
            <option value="WebPage" {% if info_type == 'WebPage' %}selected{% endif %}>WebPage</option>
            <option value="AboutPage" {% if info_type == 'AboutPage' %}selected{% endif %}>AboutPage</option>
            <option value="FAQPage" {% if info_type == 'FAQPage' %}selected{% endif %}>FAQPage</option>
            <option value="ContactPage" {% if info_type == 'ContactPage' %}selected{% endif %}>ContactPage</option>
        </select>
    </div>
</div>

<div class="form-group">
    <label class="col-sm-3 control-label">{{ entry_author_name }}</label>
    <div class="col-sm-9">
        <input type="text" name="author_name" value="{{ author_name }}" class="form-control">
    </div>
</div>

<div class="form-group">
    <label class="col-sm-3 control-label">{{ entry_author_url }}</label>
    <div class="col-sm-9">
        <input type="url" name="author_url" value="{{ author_url }}" class="form-control" placeholder="https://...">
    </div>
</div>

