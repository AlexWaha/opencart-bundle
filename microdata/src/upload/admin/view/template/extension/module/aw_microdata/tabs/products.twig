<div class="form-group">
    <label class="col-sm-3 control-label">{{ entry_gtin_source }}</label>
    <div class="col-sm-9">
        <select name="gtin_source" class="form-control">
            {% set gtin_sources = ['ean','upc','jan','isbn','mpn','sku','location','custom'] %}
            {% for opt in gtin_sources %}
            <option value="{{ opt }}" {% if gtin_source == opt %}selected{% endif %}>{{ attribute(_context, 'text_gtin_source_' ~ opt) ?? opt|upper }}</option>
            {% endfor %}
        </select>
        <select name="gtin_custom_attribute_id" class="form-control" style="margin-top:6px;{% if gtin_source != 'custom' %}display:none;{% endif %}" data-gtin-custom>
            <option value="0">-- {{ text_select|default('Select') }} --</option>
            {% for attr in attributes_list %}
            <option value="{{ attr.attribute_id }}" {% if gtin_custom_attribute_id == attr.attribute_id %}selected{% endif %}>{{ attr.name }}</option>
            {% endfor %}
        </select>
    </div>
</div>

