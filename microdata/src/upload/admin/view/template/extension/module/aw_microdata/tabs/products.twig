<div class="form-group">
    <label class="col-sm-3 control-label">{{ entry_availability_map }}</label>
    <div class="col-sm-9">
        <table class="table table-bordered table-condensed">
            <thead>
                <tr>
                    <th>{{ text_stock_status }}</th>
                    <th>{{ text_schema_value }}</th>
                </tr>
            </thead>
            <tbody>
                {% for ss in stock_statuses %}
                <tr>
                    <td>{{ ss.name }}</td>
                    <td>
                        <select name="availability_map[{{ ss.stock_status_id }}]" class="form-control input-sm">
                            <option value="InStock" {% if availability_map[ss.stock_status_id] is defined and availability_map[ss.stock_status_id] == 'InStock' %}selected{% endif %}>InStock</option>
                            <option value="OutOfStock" {% if availability_map[ss.stock_status_id] is defined and availability_map[ss.stock_status_id] == 'OutOfStock' %}selected{% endif %}>OutOfStock</option>
                            <option value="PreOrder" {% if availability_map[ss.stock_status_id] is defined and availability_map[ss.stock_status_id] == 'PreOrder' %}selected{% endif %}>PreOrder</option>
                            <option value="BackOrder" {% if availability_map[ss.stock_status_id] is defined and availability_map[ss.stock_status_id] == 'BackOrder' %}selected{% endif %}>BackOrder</option>
                            <option value="SoldOut" {% if availability_map[ss.stock_status_id] is defined and availability_map[ss.stock_status_id] == 'SoldOut' %}selected{% endif %}>SoldOut</option>
                            <option value="LimitedAvailability" {% if availability_map[ss.stock_status_id] is defined and availability_map[ss.stock_status_id] == 'LimitedAvailability' %}selected{% endif %}>LimitedAvailability</option>
                        </select>
                    </td>
                </tr>
                {% endfor %}
            </tbody>
        </table>
    </div>
</div>

<div class="form-group">
    <label class="col-sm-3 control-label">{{ entry_shipping_details }}</label>
    <div class="col-sm-9">
        <label class="checkbox-switch">
            <input type="hidden" name="shipping_details" value="0">
            <input type="checkbox" name="shipping_details" value="1" {% if shipping_details %}checked{% endif %}>
            <span class="checkbox-switch-slider"></span>
        </label>
        <p class="help-block">{{ help_shipping_details }}</p>
        <div class="row" style="margin-top:10px;">
            <div class="col-sm-3">
                <label>{{ text_shipping_rate }}</label>
                <input type="text" name="shipping_rate_value" value="{{ shipping_rate_value }}" class="form-control input-sm" placeholder="0">
            </div>
            <div class="col-sm-2">
                <label>{{ text_currency }}</label>
                <input type="text" name="shipping_rate_currency" value="{{ shipping_rate_currency }}" class="form-control input-sm" maxlength="3" placeholder="UAH">
            </div>
            <div class="col-sm-3">
                <label>{{ text_destination_country }}</label>
                <select name="shipping_destination_country" class="form-control input-sm">
                    <option value="UA" {% if shipping_destination_country == 'UA' %}selected{% endif %}>UA — Ukraine</option>
                    <option value="PL" {% if shipping_destination_country == 'PL' %}selected{% endif %}>PL — Poland</option>
                    <option value="DE" {% if shipping_destination_country == 'DE' %}selected{% endif %}>DE — Germany</option>
                    <option value="CZ" {% if shipping_destination_country == 'CZ' %}selected{% endif %}>CZ — Czech Republic</option>
                    <option value="SK" {% if shipping_destination_country == 'SK' %}selected{% endif %}>SK — Slovakia</option>
                    <option value="RO" {% if shipping_destination_country == 'RO' %}selected{% endif %}>RO — Romania</option>
                    <option value="HU" {% if shipping_destination_country == 'HU' %}selected{% endif %}>HU — Hungary</option>
                    <option value="LT" {% if shipping_destination_country == 'LT' %}selected{% endif %}>LT — Lithuania</option>
                    <option value="LV" {% if shipping_destination_country == 'LV' %}selected{% endif %}>LV — Latvia</option>
                    <option value="EE" {% if shipping_destination_country == 'EE' %}selected{% endif %}>EE — Estonia</option>
                    <option value="US" {% if shipping_destination_country == 'US' %}selected{% endif %}>US — United States</option>
                    <option value="GB" {% if shipping_destination_country == 'GB' %}selected{% endif %}>GB — United Kingdom</option>
                </select>
            </div>
        </div>
        <div class="row" style="margin-top:10px;">
            <div class="col-sm-3">
                <label>{{ text_handling_min }}</label>
                <input type="number" name="handling_min" value="{{ handling_min }}" class="form-control input-sm" min="0">
            </div>
            <div class="col-sm-3">
                <label>{{ text_handling_max }}</label>
                <input type="number" name="handling_max" value="{{ handling_max }}" class="form-control input-sm" min="0">
            </div>
            <div class="col-sm-3">
                <label>{{ text_transit_min }}</label>
                <input type="number" name="transit_min" value="{{ transit_min }}" class="form-control input-sm" min="0">
            </div>
            <div class="col-sm-3">
                <label>{{ text_transit_max }}</label>
                <input type="number" name="transit_max" value="{{ transit_max }}" class="form-control input-sm" min="0">
            </div>
        </div>
    </div>
</div>

